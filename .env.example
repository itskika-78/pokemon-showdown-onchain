# ---- Solana / Helius DAS (server-side ONLY — never NEXT_PUBLIC_*) ----
# Get a key at https://helius.dev
HELIUS_API_KEY=
# Optional overrides (auto-built from HELIUS_API_KEY when omitted):
# HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=...
# HELIUS_DEVNET_RPC_URL=https://devnet.helius-rpc.com/?api-key=...

# Verified Phygitals collection grouping value on Solana (real, June 2026).
PHYGITALS_COLLECTION_MINTS=BSG6DyEihFFtfvxtL9mKYsvTwiZXB1rq5gARMTJC2xAM

# Default network when no Settings override in Redis (devnet | mainnet).
DAS_MODE=devnet
# NODE_ENV=production
# JWT_SECRET=<strong-random-secret>
# LOG_SIGNING_SECRET=<strong-random-secret>
# HELIUS_API_KEY=<your-key>
# TREASURY_WALLET=<pubkey>
# ESCROW_SECRET_KEY=<base58-or-json-array>
# HELIUS_WEBHOOK_SECRET=<random>
# SIWS_DOMAIN=yourdomain.com
# SIWS_URI=https://yourdomain.com
# WEB_ORIGIN=https://yourdomain.com
# NEXT_PUBLIC_WS_URL=wss://your-battle-service.example.com
# DATABASE_URL=postgres://...
# REDIS_URL=redis://...

# Treasury wallet — receives devnet marketplace payments and platform fees.
TREASURY_WALLET=
NEXT_PUBLIC_TREASURY_WALLET=

# Magic Eden API key (optional — collection stats only; mainnet buys happen externally).
MAGICEDEN_API_KEY=
MAGICEDEN_COLLECTION_SYMBOL=phygitals

# Pokemon TCG API (optional, server-only).
# POKEMONTCG_API_KEY=

# Escrow hot wallet for SOL wagers (base58 or JSON byte array). Dev fallback: .runtime/escrow-devnet.json
# ESCROW_SECRET_KEY=

# Helius webhook auth (required in production).
# HELIUS_WEBHOOK_SECRET=

# ---- Auth (Phase 2) ----
# Sign-In With Solana → session JWT.
JWT_SECRET=dev-only-change-me-please
SIWS_DOMAIN=localhost:3000
SIWS_STATEMENT=Sign in to PokéChain
SIWS_URI=http://localhost:3000
SESSION_TTL_SECONDS=86400

# ---- Datastores (Phase 1) ----
DATABASE_URL=postgres://battler:battler@localhost:5432/battler
REDIS_URL=redis://localhost:6379

# ---- Battle service / realtime (Phase 6/8) ----
BATTLE_SERVICE_PORT=3001
WEB_ORIGIN=http://localhost:3000
TURN_TIMER_SECONDS=60
RECONNECT_WINDOW_SECONDS=30

# ---- Game config ----
# 'gen9customgame' lets us set arbitrary level/EVs/IVs/moves per Pokémon.
BATTLE_FORMAT=gen9customgame
# Derivation algorithm version — bump to force re-derivation of battle profiles.
DERIVATION_VERSION=1
# Platform fee taken at settlement, in basis points (250 = 2.5%).
PLATFORM_FEE_BPS=250

# ---- Phase 10: signed battle logs ----
# Optional ECDSA private key (PEM) for publicly-verifiable log signatures.
# If absent, logs are signed with HMAC using LOG_SIGNING_SECRET (dev only).
# LOG_SIGNING_PRIVATE_KEY=
LOG_SIGNING_SECRET=dev-only-log-signing-secret

# ---- Frontend (apps/web) ----
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_WS_URL=http://localhost:3001
# Server-only battle-service URL for production (no rebuild). Overrides NEXT_PUBLIC_WS_URL in /api/config.
BATTLE_WS_PUBLIC_URL=
# Wallet ConnectionProvider endpoints — use public Solana RPC only (never Helius keys here).
# Server-side HELIUS_RPC_URL / HELIUS_DEVNET_RPC_URL hold your API keys securely.
NEXT_PUBLIC_HELIUS_RPC_URL=https://api.mainnet-beta.solana.com
NEXT_PUBLIC_HELIUS_DEVNET_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_SOLANA_CLUSTER=devnet
NEXT_PUBLIC_SPRITE_HOST=https://play.pokemonshowdown.com/sprites
# Show real Pokémon names/sprites only behind this flag (IP risk — see docs/RISKS.md).
NEXT_PUBLIC_ENABLE_POKEMON_ART=true
